# http://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Configuration spécifique pour XML et JSON (2 espaces)
[*.{xml,json}]
indent_size = 2

# Les fichiers YAML (souvent utilisés en Spring) demandent aussi généralement 2 espaces
[*.{yml,yaml}]
indent_size = 2

# Spécifique au Markdown
[*.md]
trim_trailing_whitespace = false